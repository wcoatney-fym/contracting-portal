# Supabase Configuration
# Copy this file to .env and fill in your values
# Also add these to your hosting platform's environment variables

VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service account for database access (shared by all portal users)
VITE_SERVICE_EMAIL=service@teamfym.com
VITE_SERVICE_PASSWORD=your-service-password-here

# Application URL
# This is the production URL where agents will access their forms
# IMPORTANT: Update this to match your Bolt.new shortened domain
VITE_APP_URL=https://your-app-url-here
